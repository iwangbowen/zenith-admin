{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Server",
      "runtimeExecutable": "${workspaceFolder}/packages/server/node_modules/.bin/tsx",
      "args": ["${workspaceFolder}/packages/server/src/index.ts"],
      "cwd": "${workspaceFolder}/packages/server",
      "sourceMaps": true,
      "envFile": "${workspaceFolder}/packages/server/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Web",
      "runtimeExecutable": "pnpm",
      "args": ["--filter", "@zenith/web", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug: Full Stack",
      "configurations": ["Debug: Server", "Debug: Web"],
      "stopAll": true
    }
  ]
}
