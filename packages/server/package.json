{
  "name": "@zenith/server",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/db/migrate.ts && tsx src/db/seed.ts && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@zenith/shared": "*",
    "ali-oss": "^6.23.0",
    "bcryptjs": "^3.0.3",
    "china-division": "^2.7.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "hono": "^4.12.9",
    "ip-range-check": "^0.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "postgres": "^3.4.8",
    "svg-captcha": "^1.4.0",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/ua-parser-js": "^0.7.39",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
