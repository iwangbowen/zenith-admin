{
  "name": "@zenith/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/db/migrate.ts && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@zenith/shared": "workspace:*",
    "ali-oss": "^6.23.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.5",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/ua-parser-js": "^0.7.39",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
