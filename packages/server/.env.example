# ─── 服务器 ──────────────────────────────────────────────────────────────────
PORT=3300

# ─── 认证 ────────────────────────────────────────────────────────────────────
JWT_SECRET=zenith-admin-secret
# 生产环境请配置独立字段加密密钥（建议随机 32 字节十六进制），用于报表凭据等敏感字段
# FIELD_ENCRYPTION_KEY=

# ─── 数据库（PostgreSQL）──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zenith_admin

# ─── Redis（会话持久化）────────────────────────────────────────────────────────
# 方式一：URL 格式（推荐，支持带密码的连接）
REDIS_URL=redis://127.0.0.1:6379
# 带密码示例：
# REDIS_URL=redis://:your_password@127.0.0.1:6379/0

# 方式二：逐项配置（与 REDIS_URL 二选一，REDIS_URL 优先）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_KEY_PREFIX=zenith:   # 所有 Redis key 的命名空间前缀（默认 zenith:）

# ─── 日志 ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILES=30d

# ─── 运行环境 ──────────────────────────────────────────────────────────────────
# 设置为 true 时，每个响应会附加 Server-Timing 头，可在 Chrome DevTools → Network → Timing 查看各阶段耗时
# 建议生产环境设为 false，避免暴露内部性能信息
SERVER_TIMING_ENABLED=false

# ─── 可观测性（Prometheus / OpenTelemetry）───────────────────────────────────
# Prometheus 指标默认暴露在 GET /metrics，无需额外配置。
# OpenTelemetry tracing：
# - OTEL_ENABLED=true 时强制启用
# - 若未显式设置 OTEL_ENABLED，但配置了 OTLP endpoint，也会自动启用
OTEL_ENABLED=false
OTEL_SERVICE_NAME=zenith-admin-server
# 可选：未设置时默认读取当前 npm package version
# OTEL_SERVICE_VERSION=0.5.0

# 可选：OTLP traces 专用 HTTP 导出地址（推荐）
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# 可选：通用 OTLP 端点（未设置 traces endpoint 时使用）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# 可选：OTLP 导出请求头，逗号分隔。
# 示例：OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xxx,x-honeycomb-team=xxx
# OTEL_EXPORTER_OTLP_HEADERS=

# ─── 请求限制 ──────────────────────────────────────────────────────────────────
# 请求体大小限制（单位：字节）。0 或未设置 = 不限制（使用运行时默认）
# 建议：普通 10MB=10485760；允许大文件上传设为 104857600（100MB）或更大
REQUEST_BODY_LIMIT=0

# 请求超时（单位：毫秒）。0 或未设置 = 不启用超时中间件
# 启用后自动排除：/api/ws、/api/files、/api/db-backups 及所有 /export 接口
REQUEST_TIMEOUT_MS=0

# ─── 安全 ────────────────────────────────────────────────────────────────────
# CSRF 允许的来源白名单，逗号分隔。留空 = 开发模式不限制来源
# 生产环境强烈建议配置，防止跨站请求伪造（CSRF）攻击
# 示例：ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com
ALLOWED_ORIGINS=

# 报表 API/Webhook/外部数据库默认禁止访问 localhost、私网及保留地址。
# 确需连接可信内网数据源时，显式配置主机名、IP 或 CIDR，逗号分隔。
# 示例：REPORT_OUTBOUND_PRIVATE_ALLOWLIST=db.internal,10.20.0.0/16
REPORT_OUTBOUND_PRIVATE_ALLOWLIST=

# ─── WebRTC 音视频通话 ────────────────────────────────────────────────────────
# 聊天模块的 1v1 / 群语音 / 视频通话信令复用 /api/ws，媒体走 P2P。
# 浏览器创建 RTCPeerConnection 时使用的 ICE 服务器（STUN/TURN）由本段决定，
# 通过 GET /api/chat/rtc/config 下发给前端。
#
# STUN 用于发现公网地址（多地址逗号分隔）；默认公共 STUN 可满足同 LAN/本机连通。
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
#
# ⚠️ 跨 NAT / 公网通话必须配置 TURN 中继，否则双方无法穿透时通话会失败。
# 可自建 coturn 或使用云服务商提供的 TURN。多地址逗号分隔。
# 示例：
# WEBRTC_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# WEBRTC_TURN_USERNAME=zenith
# WEBRTC_TURN_CREDENTIAL=your_turn_password
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# ─── HTTP 流量日志（对标 Zalando Logbook）────────────────────────────────────
#
# 入站（Incoming）：记录进入本系统的 HTTP 请求/响应
# 出站（Outgoing）：记录本系统通过 http-client.ts 发出的外部请求
#
# 级别说明（从低到高）：
#   off     - 不记录任何内容
#   access  - 仅记录方法/URL/状态码/耗时（最轻量，无 body 开销）
#   headers - access + 请求/响应 Headers
#   body    - access + 请求/响应 Body
#   full    - 全量（access + headers + body）
#
# 格式：
#   json    - 结构化 NDJSON（推荐，适合 ELK / Grafana）
#   text    - 多行人类可读格式（适合开发调试）
#   curl    - 请求阶段生成可重放的 curl 命令（适合复现问题）

# ── 入站日志 ──────────────────────────────────────────────────────────────────
# 全局开关（默认关闭，按需开启）
HTTP_LOG_INCOMING_ENABLED=false

# 默认记录级别（未被方法级别覆盖时生效）
HTTP_LOG_INCOMING_LEVEL=access

# 方法级别覆盖（可精细控制每类 HTTP 方法的记录详细度）
# HTTP_LOG_INCOMING_METHOD_GET=off       # GET 查询类通常不需要 body
# HTTP_LOG_INCOMING_METHOD_POST=full     # POST 写接口全量记录
# HTTP_LOG_INCOMING_METHOD_PUT=body      # PUT 只记录 body
# HTTP_LOG_INCOMING_METHOD_PATCH=body
# HTTP_LOG_INCOMING_METHOD_DELETE=headers

# 输出格式（json / text / curl）
HTTP_LOG_INCOMING_FORMAT=json

# 单个 body 最大捕获字节数，超出时截断（0 = 不限制）
HTTP_LOG_INCOMING_MAX_BODY=65536

# 是否同时记录响应体（需克隆 Response，有轻微性能开销，默认关闭）
# 建议仅在排查问题时临时开启
HTTP_LOG_INCOMING_RESPONSE_BODY=false

# 不记录日志的追加排除路径（逗号分隔，追加到内置排除列表之后）
# 内置排除：/api/health, /api/ws, /api/metrics, /docs, /api/ui
# HTTP_LOG_INCOMING_EXCLUDE=/api/files,/api/db-backups

# 是否写入独立的 http-traffic-YYYY-MM-DD.log（默认合并进 app-*.log）
# 日志量大时建议开启，避免 app 日志被流量日志淹没
HTTP_LOG_INCOMING_FILE=false

# ── 出站日志 ──────────────────────────────────────────────────────────────────
# 全局开关（默认关闭，按需开启）
HTTP_LOG_OUTGOING_ENABLED=false

# 默认记录级别（出站默认 full，便于排查第三方集成问题）
HTTP_LOG_OUTGOING_LEVEL=full

# 方法级别覆盖
# HTTP_LOG_OUTGOING_METHOD_GET=access    # 常规查询降级
# HTTP_LOG_OUTGOING_METHOD_POST=full

# 输出格式（json / text / curl）
HTTP_LOG_OUTGOING_FORMAT=json

# 单个 body 最大捕获字节数
HTTP_LOG_OUTGOING_MAX_BODY=4096

# 是否记录出站响应体（出站默认开启，便于排查第三方接口返回）
HTTP_LOG_OUTGOING_RESPONSE_BODY=true

# 是否将出站日志写入独立的 http-traffic-*.log（默认合并到 app-*.log）
# HTTP_LOG_OUTGOING_FILE=false
